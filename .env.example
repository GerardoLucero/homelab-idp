# homelab-idp — required variables
# Copy this file, fill in values, and load via Vault or External Secrets

# ── Cluster ─────────────────────────────────────────────────────
CLUSTER_NAME=homelab
CLUSTER_ENDPOINT=https://<CONTROL_PLANE_VIP>:6443
CLUSTER_DOMAIN=home.lab

# ── Network ──────────────────────────────────────────────────────
METALLB_IP_RANGE=192.168.68.200-192.168.68.250
CLOUDFLARE_API_TOKEN=<CLOUDFLARE_API_TOKEN>
CLOUDFLARE_TUNNEL_TOKEN=<CLOUDFLARE_TUNNEL_TOKEN>
CLOUDFLARE_ZONE_ID=<CLOUDFLARE_ZONE_ID>

# ── Authentik (SSO) ───────────────────────────────────────────────
AUTHENTIK_SECRET_KEY=<RANDOM_50_CHAR_STRING>
AUTHENTIK_POSTGRES_PASSWORD=<STRONG_PASSWORD>

# ── GitLab ────────────────────────────────────────────────────────
GITLAB_ROOT_PASSWORD=<STRONG_PASSWORD>
GITLAB_REGISTRY_STORAGE=<GCS_OR_S3_CONFIG>

# ── Harbor ────────────────────────────────────────────────────────
HARBOR_ADMIN_PASSWORD=<STRONG_PASSWORD>
HARBOR_DATABASE_PASSWORD=<STRONG_PASSWORD>
HARBOR_CORE_SECRET=<RANDOM_32_CHARS>
HARBOR_JOBSERVICE_SECRET=<RANDOM_32_CHARS>

# ── Backstage ─────────────────────────────────────────────────────
BACKSTAGE_GITLAB_TOKEN=<GITLAB_PAT_WITH_READ_API>
BACKSTAGE_POSTGRES_PASSWORD=<STRONG_PASSWORD>
BACKSTAGE_BACKEND_SECRET=<RANDOM_32_CHARS>
BACKSTAGE_ARGOCD_TOKEN=<ARGOCD_API_TOKEN>
BACKSTAGE_K8S_SA_TOKEN=<SERVICE_ACCOUNT_TOKEN>
BACKSTAGE_SONARQUBE_TOKEN=<SONARQUBE_USER_TOKEN_BASE64>
BACKSTAGE_GRAFANA_TOKEN=<GRAFANA_SERVICE_ACCOUNT_TOKEN>

# ── SonarQube ─────────────────────────────────────────────────────
SONARQUBE_POSTGRES_PASSWORD=<STRONG_PASSWORD>
SONARQUBE_ADMIN_PASSWORD=<STRONG_PASSWORD>

# ── Vault ─────────────────────────────────────────────────────────
VAULT_UNSEAL_KEY_1=<UNSEAL_KEY>
VAULT_UNSEAL_KEY_2=<UNSEAL_KEY>
VAULT_UNSEAL_KEY_3=<UNSEAL_KEY>
VAULT_ROOT_TOKEN=<ROOT_TOKEN>

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_DEMO_POSTGRES_PASSWORD=<STRONG_PASSWORD>
KAFKA_DEBEZIUM_USER=debezium
KAFKA_DEBEZIUM_PASSWORD=<STRONG_PASSWORD>

# ── Monitoring ────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=<STRONG_PASSWORD>
GRAFANA_OIDC_CLIENT_ID=<AUTHENTIK_CLIENT_ID>
GRAFANA_OIDC_CLIENT_SECRET=<AUTHENTIK_CLIENT_SECRET>

# ── ArgoCD ────────────────────────────────────────────────────────
ARGOCD_ADMIN_PASSWORD=<BCRYPT_HASHED_PASSWORD>
ARGOCD_GITLAB_USERNAME=root
ARGOCD_GITLAB_TOKEN=<GITLAB_PAT>

# ── Kong ──────────────────────────────────────────────────────────
KONG_POSTGRES_PASSWORD=<STRONG_PASSWORD>
